# Supabase — ambil dari Project Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Google Apps Script — URL setelah deploy sebagai web app
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Google Drive folder ID tempat foto disimpan (opsional, bisa di-hardcode di Apps Script)
VITE_DRIVE_FOLDER_ID=your_folder_id_here

# Password tersembunyi untuk semua akun staff (jangan dibagikan ke staff)
VITE_STAFF_PASS=your_staff_shared_password_here
